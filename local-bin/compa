#!/bin/bash
#!/usr/bin/env bash
# GNOME 확장 호환성 최신 체크 – extensions.gnome.org API + jq
# 사용법: ./gnome-extension-online-check.sh <target-shell-version>
# 예: ./gnome-extension-online-check.sh 46
VERSION=$(gnome-shell --version | grep -oP '\d+' | head -n 1)
CHECK_VERSION=$((VERSION - 3))
#CHECK_VERSION=42

TARGET_VERSION="$1"
if [[ -z "$TARGET_VERSION" ]]; then
  echo "사용법: $0 <GNOME Shell 버전>"
  exit 1
fi

for cmd in curl jq; do
  if ! command -v $cmd &>/dev/null; then
    echo "❌ $cmd 명령어가 필요합니다. 설치 후 다시 실행해주세요."
    exit 1
  fi
done

EXT_DIRS=(
  "$HOME/.local/share/gnome-shell/extensions"
  "/usr/share/gnome-shell/extensions"
)

echo "=== 서버 기준 최신 확장 호환성 체크 ==="
echo "목표 GNOME Shell 버전: $TARGET_VERSION"
echo

for DIR in "${EXT_DIRS[@]}"; do
  [[ -d "$DIR" ]] || continue
  for EXT in "$DIR"/*; do
    META="$EXT/metadata.json"
    [[ -f "$META" ]] || continue

    NAME=$(basename "$EXT")
    UUID=$(jq -r '.uuid // .["shell-version"]? // empty' "$META")
    [[ -z "$UUID" ]] && UUID="$NAME"

	NAME=${NAME%@*} #@ 이메일 자르기

    JSON=$(curl -s "https://extensions.gnome.org/extension-info/?uuid=${UUID}")
    SUPPORTED=$(echo "$JSON" | jq -r '.shell_version_map | keys | .[]' | sort -V | paste -sd "," -)
    STATUS="❌"
    if echo ",$SUPPORTED," | grep -q ",${TARGET_VERSION},"; then
      STATUS="✅"
    fi

    #echo "$NAME ($UUID) → 지원 버전: [$SUPPORTED] → $STATUS"
    SUPPORTED=$(echo "$SUPPORTED" | tr -d '[]' | awk -v RS=, '{if ($1 > '$CHECK_VERSION') printf "%s,", $1}' | sed 's/,$//')
	#SUPPORTED="[${NEW_SUPPORTED}]"	
	
    echo "$STATUS $NAME → [$SUPPORTED]"
  done
done
